{
	"name": "surrealql",
	"displayName": "SurrealQL",
	"description": "Syntax highlighting and snippets for SurrealQL, the query language for SurrealDB",
	"version": "0.3.0",
	"publisher": "surrealdb",
	"icon": "./icon.png",
	"author": {
		"name": "SurrealDB",
		"url": "https://surrealdb.com"
	},
	"homepage": "https://github.com/surrealdb/surrealql-grammar",
	"packageManager": "bun@1.3.11",
	"scripts": {
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"lint:check": "biome check . --formatter-enabled=false",
		"lint:apply": "biome check . --formatter-enabled=false --write",
		"lint:apply:unsafe": "biome check . --formatter-enabled=false --write --unsafe",
		"test": "bun test test/textmate",
		"test:textmate": "bun test test/textmate",
		"validate": "bun run typecheck && biome check . && bun run test"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/surrealdb/surrealql-grammar.git"
	},
	"engines": {
		"vscode": "^1.77.0"
	},
	"categories": [
		"Programming Languages",
		"Snippets"
	],
	"contributes": {
		"languages": [
			{
				"id": "surrealql",
				"aliases": [
					"SurrealQL",
					"surrealql"
				],
				"extensions": [
					".surql",
					".surrealql"
				],
				"configuration": "./language-configuration.json",
				"icon": {
					"light": "./icon.png",
					"dark": "./icon.png"
				}
			}
		],
		"grammars": [
			{
				"language": "surrealql",
				"scopeName": "source.surrealql",
				"path": "./syntaxes/surrealql.tmLanguage.json",
				"embeddedLanguages": {
					"meta.embedded.block.javascript": "javascript"
				}
			},
			{
				"injectTo": [
					"source.js",
					"source.js.jsx",
					"source.jsx",
					"source.ts",
					"source.tsx",
					"source.vue",
					"source.surrealql"
				],
				"scopeName": "inline.surrealql-js-literal",
				"path": "./syntaxes/surrealql-js-literal.tmLanguage.json",
				"embeddedLanguages": {
					"meta.embedded.block.surrealql": "surrealql"
				}
			},
			{
				"scopeName": "markdown.surrealql.codeblock",
				"path": "./syntaxes/surrealql-markdown.tmLanguage.json",
				"injectTo": [
					"text.html.markdown",
					"source.mdx"
				],
				"embeddedLanguages": {
					"meta.embedded.block.surrealql": "surrealql"
				}
			}
		],
		"snippets": [
			{
				"language": "surrealql",
				"path": "./snippets.json"
			}
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@types/bun": "^1.2.0",
		"typescript": "^5.7.0",
		"vscode-oniguruma": "^2.0.1",
		"vscode-textmate": "^9.3.2"
	}
}
